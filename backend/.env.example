# Connection string do PostgreSQL (Supabase)
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"

# Direct connection para migrations
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# URL do projeto Supabase
SUPABASE_URL="https://seu-projeto.supabase.co"

# Service role key (acesso total ao storage)
SUPABASE_SERVICE_KEY="sb_secret_..."

# Nome do bucket no Supabase Storage
SUPABASE_BUCKET="filelocker-files"

# Porta do servidor NestJS
PORT=3000

# Ambiente (development/production)
NODE_ENV="development"

# Chave secreta para geração de JWT
JWT_SECRET="troque-por-uma-chave-segura"